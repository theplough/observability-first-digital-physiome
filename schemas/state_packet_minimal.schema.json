{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimal observability-first state packet",
  "type": "object",
  "required": [
    "packet_id",
    "framework_version",
    "validation_level",
    "subject_context",
    "event_log",
    "observed_signal_frame",
    "state_packets",
    "quality",
    "claim_boundary"
  ],
  "properties": {
    "packet_id": {"type": "string"},
    "framework_version": {"type": "string"},
    "validation_level": {"type": "string"},
    "subject_context": {
      "type": "object",
      "required": ["subject_id", "population_boundary"],
      "properties": {
        "subject_id": {"type": "string"},
        "population_boundary": {"type": "string"}
      }
    },
    "event_log": {
      "type": "array",
      "items": {"type": "string"}
    },
    "observed_signal_frame": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signal_id", "value", "unit", "quality"],
        "properties": {
          "signal_id": {"type": "string"},
          "value": {"type": ["number", "null"]},
          "unit": {"type": "string"},
          "quality": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "state_packets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["state", "confidence"],
        "properties": {
          "state": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "quality": {
      "type": "object",
      "required": ["window_quality", "degradations", "forbidden_outputs"],
      "properties": {
        "window_quality": {"type": "number", "minimum": 0, "maximum": 1},
        "degradations": {"type": "array", "items": {"type": "string"}},
        "forbidden_outputs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "claim_boundary": {"type": "string"}
  }
}
